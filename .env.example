# ===========================================
# LinkedIn Leads Intelligence System
# Copy this file to .env and fill in values
# ===========================================

# --- OpenAI API ---
# Required for: classification, scoring, reply generation, voice, embeddings
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Model Overrides (optional) ---
# Defaults: o3, gpt-5, gpt-4o-mini
# CLASSIFY_MODEL=o3
# GENERATION_MODEL=gpt-5
# FAST_MODEL=gpt-4o-mini

# --- Qdrant Vector Database (optional) ---
# Required for: semantic search, embeddings (Phase 4B)
# Default: http://localhost:6333 (run locally with Docker)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# --- Google Calendar API (optional) ---
# Required for: calendar booking agent (Phase 3B)
# Download OAuth credentials from Google Cloud Console:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create OAuth 2.0 Client ID (Desktop app)
#   3. Download JSON and save as data/google_credentials.json
# The token will be auto-generated on first use.

# --- Chrome DevTools Protocol ---
# Default: 9222
# CDP_PORT=9222

# --- Approved-sender gating ---
# Set to 1 to allow the review UI's "Send Approved (live)" button to
# actually dispatch messages. Dry-runs are always allowed.
# LINKEDIN_SEND_ENABLED=0

# Soft cap on sends per hour. Translated into per-run delay + max envs
# by pipeline.review_server. Default: 12.
# SENDER_RATE_LIMIT=12

# LinkedIn display name used by the sender to distinguish outbound
# messages. Must match your LinkedIn profile.
# LINKEDIN_USER_NAME=Nicholas J. Fleischhauer

# --- VPC / Docker Deployment ---
# VNC password for the remote desktop (default: linkedin)
# VNC_PASSWORD=linkedin

# --- Health Monitor ---
# Telegram bot for push notifications when services go down
# Create a bot via @BotFather, then get your chat ID via @userinfobot
# HEALTH_TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# HEALTH_TELEGRAM_CHAT_ID=123456789

# Generic webhook (Slack, Discord, ntfy.sh, etc.)
# HEALTH_WEBHOOK_URL=https://hooks.slack.com/services/...

# How often to check health (seconds, default: 60)
# HEALTH_CHECK_INTERVAL=60

# How often to re-send alerts if still down (seconds, default: 1800 = 30 min)
# HEALTH_ALERT_REMIND_INTERVAL=1800

# Docker Compose: listener exposes HTTP health on port 3765 (set automatically in docker-compose.yml)
# HEALTH_LISTENER_URL=http://listener:3765

# --- Caddy Reverse Proxy ---
# Domain for HTTPS (used by Caddyfile)
# DOMAIN=yourdomain.com
# BASIC_AUTH_USER=admin
# BASIC_AUTH_HASH=  # generate with: caddy hash-password --plaintext yourpassword
